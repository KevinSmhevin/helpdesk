DATABASE_URL=postgresql://user:password@localhost:5432/helpdesk
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
PORT=3000
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.com
ANTHROPIC_API_KEY=
SENDGRID_API_KEY=
# Webhook token — append to SendGrid Inbound Parse URL as ?token=<value>
# Generate with: openssl rand -hex 32
SENDGRID_WEBHOOK_SECRET=
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# E2E testing: also create .env.test with these same keys, but:
#   DATABASE_URL -> helpdesk_test database
#   BETTER_AUTH_URL -> http://localhost:3001
#   PORT -> 3001
#   ALLOWED_ORIGINS -> http://localhost:5174
#   NODE_ENV -> test
# Create the test DB: createdb helpdesk_test
